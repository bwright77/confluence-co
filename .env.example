# Local development only — copy to `.env.local` (gitignored) and fill in
# Stripe TEST-mode keys to exercise the donate flow with `vercel dev`.
# Production values live in the Vercel dashboard (Production environment).

# Server-only. Used by api/create-checkout-session.ts and api/checkout-session.ts.
# Never prefix with VITE_ — that would expose it to the client bundle.
STRIPE_SECRET_KEY=sk_test_...

# Safe to be public. Not required for the hosted-redirect flow; reserved for a
# future Payment Element integration.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
