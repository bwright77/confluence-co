{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/programs/pathways", "destination": "/focus-areas/youth-pathways", "permanent": true },
    { "source": "/programs/watershed", "destination": "/focus-areas/watershed-restoration", "permanent": true },
    { "source": "/programs/mo-betta", "destination": "/focus-areas/public-health-urban-agriculture", "permanent": true },
    { "source": "/programs/recreation", "destination": "/focus-areas/outdoor-recreation-stream", "permanent": true },
    { "source": "/programs/cultural", "destination": "/focus-areas/cultural-programs", "permanent": true },
    { "source": "/programs/civic", "destination": "/focus-areas/civic-engagement", "permanent": true }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
